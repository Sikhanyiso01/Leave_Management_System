@model Leave_Management_System.web.Data.LeaveType

@{
    ViewData["Title"] = "Create Leave Type";
}

<h1>Create Leave Type</h1>


<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="name" class="control-label"></label>
                <input asp-for="name" class="form-control" />
                <span asp-validation-for="name" class="text-danger"></span>
            </div>
            <br/>
            <div class="form-group">
                <label asp-for="numberOfDays" class="control-label"></label>
                <input asp-for="numberOfDays" class="form-control" />
                <span asp-validation-for="numberOfDays" class="text-danger"></span>
            </div>
            <br />
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-primary">Back to List</a>
            </div>
        </form>
    </div>
    
</div>
